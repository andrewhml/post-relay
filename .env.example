# Post Relay local environment template
# Copy to a private local .env file and fill in values for the integrations you use.
# Do NOT commit real secrets, tokens, app secrets, bot tokens, or R2 keys.

# -----------------------------------------------------------------------------
# Meta / Instagram Graph integration (optional until you validate/publish)
# Use YOUR Meta app/tester credentials and YOUR Page-linked professional IG account.
# -----------------------------------------------------------------------------
POST_RELAY_META_APP_ID=
POST_RELAY_META_APP_SECRET=
POST_RELAY_USER_ACCESS_TOKEN=
POST_RELAY_FACEBOOK_PAGE_ID=
POST_RELAY_INSTAGRAM_ACCOUNT_ID=
POST_RELAY_META_GRAPH_BASE_URL=https://graph.facebook.com
POST_RELAY_META_GRAPH_VERSION=v19.0

# Optional: a public HTTPS test image URL and caption for publish validation.
POST_RELAY_TEST_IMAGE_URL=
POST_RELAY_TEST_CAPTION=Post Relay validation test

# -----------------------------------------------------------------------------
# Discord private-DM workflow (optional; local dm commands do not need this)
# -----------------------------------------------------------------------------
POST_RELAY_DISCORD_BOT_TOKEN=
POST_RELAY_DISCORD_TARGET_USER_ID=

# -----------------------------------------------------------------------------
# Cloudflare R2 staging (optional; required only for self-managed R2 upload)
# Use S3-compatible R2 credentials. A generic Cloudflare API token is not enough.
# -----------------------------------------------------------------------------
POST_RELAY_R2_ACCOUNT_ID=
POST_RELAY_R2_ACCESS_KEY_ID=
POST_RELAY_R2_SECRET_ACCESS_KEY=
